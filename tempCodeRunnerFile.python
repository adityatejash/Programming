import numpy as np
import pandas as pd

data = {
    "A" : [1, 2, np.nan, 8, 5],
    "B" : [np.nan, 2, 3, 4, np.nan],
    "C" : ["cat","dog","rabbit","cat", np.nan]
}

df = pd.DataFrame(data)
print(df)

df['A'] = df['A'].fillna(df['A'].mean())
df['B'] = df['B'].fillna(df['B'].median())
df['C'] = df['C'].fillna(df['C'].mode()[0])

print(df)